GameName_20200107-1=&gt;	{Name}_{digit}-{digit}
GameName_20-01-07=&gt;	{Name}_{DateModified}</sys:String>

    <sys:String x:Key="LOCSsvGlobalSearchTooltip" xml:space="preserve">Añadir esta carpeta para todos los juegos.
    
