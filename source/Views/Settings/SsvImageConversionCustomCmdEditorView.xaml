<UserControl x:Class="ScreenshotsVisualizer.Views.Settings.SsvImageConversionCustomCmdEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="560"
             MinWidth="500" MinHeight="460"
             Background="{DynamicResource WindowBackgourndBrush}">

    <DockPanel Margin="10" LastChildFill="True">

        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource NormalBorderBrush}"
                Padding="0,10,0,0"
                Margin="0,10,0,0">
            <DockPanel LastChildFill="False">
                <Button Content="{DynamicResource LOCCloseLabel}"
                        DockPanel.Dock="Right"
                        Style="{StaticResource BottomButton}"
                        Click="CancelButton_Click" />
                <Button Content="{DynamicResource LOCSsvConfigSaveSource}"
                        DockPanel.Dock="Right"
                        Style="{StaticResource BottomButton}"
                        Click="SaveButton_Click" />
            </DockPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" MinHeight="100" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Label Content="{DynamicResource LOCSsvImageConversionName}" />
                <TextBox Text="{Binding WorkingCopy.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

                <Label Content="{DynamicResource LOCSsvImageConversionOutputFormat}" />
                <TextBox Text="{Binding WorkingCopy.OutputFormat, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

                <Label Content="{DynamicResource LOCSsvImageConversionQuality}" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0"
                            Minimum="1"
                            Maximum="100"
                            IsSnapToTickEnabled="True"
                            TickFrequency="1"
                            AutoToolTipPlacement="TopLeft"
                            Value="{Binding WorkingCopy.QualityValue}" />
                    <TextBlock Grid.Column="2"
                               Style="{DynamicResource BaseTextBlockStyle}"
                               VerticalAlignment="Center"
                               Text="{Binding WorkingCopy.QualityValue, StringFormat={}{0}%}" />
                </Grid>

                <CheckBox Content="{DynamicResource LOCSsvImageConversionStripMetadata}"
                          IsChecked="{Binding WorkingCopy.StripMetadata}"
                          Margin="0,0,0,10" />

                <Label Content="{DynamicResource LOCSsvImageConversionExtraArguments}" />
                <TextBox Text="{Binding WorkingCopy.ExtraArguments, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="56"
                         MaxHeight="96"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource NormalBorderBrush}"
                    BorderThickness="{DynamicResource ControlBorderThickness}"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Style="{DynamicResource SectionHeaderText}"
                               Text="{DynamicResource LOCSsvImageConversionCommandPreview}" />
                    <TextBox Grid.Row="2"
                             Text="{Binding CommandPreview, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Background="Transparent" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
