<UserControl x:Class="ScreenshotsVisualizer.Views.Settings.SsvFolderSourceEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="420" d:DesignWidth="560"
             MinWidth="480" MinHeight="360"
             Background="{DynamicResource WindowBackgourndBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="{DynamicResource LOCSsvConfigSourcePath}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" Text="{Binding WorkingCopy.ScreenshotsFolder, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="2" Content="&#xe97e;" FontFamily="{DynamicResource CommonFont}"
                    ToolTip="{DynamicResource LOCSelectDirectoryTooltip}"
                    Click="BrowseFolderButton_Click" />
        </Grid>

        <Button Grid.Row="4" HorizontalAlignment="Left"
                Content="{DynamicResource LOCCommonSelectVariable}"
                Click="SelectVariableButton_Click" />

        <StackPanel Grid.Row="6" Orientation="Horizontal">
            <ToggleButton ToolTip="{DynamicResource LOCCommonAddFilePattern}"
                          FontFamily="{DynamicResource FontIcoFont}" Content="&#xeae5;"
                          IsChecked="{Binding WorkingCopy.UsedFilePattern, FallbackValue=False}" />
            <Label Margin="8,0,0,0" Content="{DynamicResource LOCSsvFilePattern}" VerticalAlignment="Center" />
            <ToggleButton Margin="24,0,0,0" ToolTip="{DynamicResource LOCSsvScanSubFolders}"
                          FontFamily="{DynamicResource FontIcoFont}" Content="&#xee03;"
                          IsChecked="{Binding WorkingCopy.ScanSubFolders, FallbackValue=False}" />
            <Label Margin="8,0,0,0" Content="{DynamicResource LOCSsvScanSubFolders}" VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="8"
              Visibility="{Binding WorkingCopy.UsedFilePattern, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="&#xe98d;" FontFamily="{DynamicResource CommonFont}"
                    ToolTip="{DynamicResource LOCSsvNumberToDigit}"
                    Click="ReplaceDigitButton_Click" />
            <TextBox Grid.Column="2" Text="{Binding WorkingCopy.FilePattern, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.ToolTip>
                    <ToolTip Content="{DynamicResource LOCSsvFilePatternTooltip}" />
                </TextBox.ToolTip>
            </TextBox>
        </Grid>

        <Border Grid.Row="10" BorderBrush="{DynamicResource NormalBorderBrush}" BorderThickness="1" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="5" FontWeight="SemiBold" Text="{DynamicResource LOCSsvConfigPreview}" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource LOCSsvConfigTestGame}" />
                <ComboBox Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3"
                          ItemsSource="{Binding TestGames}"
                          SelectedItem="{Binding SelectedTestGame}"
                          DisplayMemberPath="Name" />

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Top" Text="{DynamicResource LOCSsvConfigSourcePath}" />
                <TextBox Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="3"
                         Text="{Binding ResolvedPath, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap" />

                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource LOCSsvFilePattern}" />
                <TextBox Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="3"
                         Text="{Binding ResolvedFilePattern, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap" />

                <TextBlock Grid.Row="8" Grid.Column="2"
                           Foreground="{DynamicResource GlyphBrush}"
                           Text="{Binding ResolvedPathStatusText}" />
                <Button Grid.Row="8" Grid.Column="4"
                        Content="&#xe97f;"
                        FontFamily="{DynamicResource CommonFont}"
                        ToolTip="{DynamicResource LOCSsvOpenScreenshotsDirectory}"
                        IsEnabled="{Binding ResolvedPathExists}"
                        Click="OpenResolvedFolderButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="12" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource NormalBorderBrush}" Padding="0,10,0,0">
            <DockPanel LastChildFill="False">
                <Button Content="{DynamicResource LOCCloseLabel}"
                        DockPanel.Dock="Right"
                        Style="{StaticResource BottomButton}"
                        Click="CancelButton_Click" />
                <Button Content="{DynamicResource LOCSsvConfigSaveSource}"
                        DockPanel.Dock="Right"
                        Style="{StaticResource BottomButton}"
                        Click="SaveButton_Click" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
