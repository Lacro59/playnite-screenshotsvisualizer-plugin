<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:CommonPluginsControls.Controls"
                    xmlns:convertersshared="clr-namespace:CommonPluginsShared.Converters">

    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <convertersshared:DefaultIconConverter x:Key="DefaultIconConverter" />

    <DataTemplate x:Key="SsvConfigurationContextRowTemplate">
        <Grid Margin="0,4" HorizontalAlignment="Stretch" ToolTip="{Binding DisplayName}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Content="&#xe97e;" FontFamily="{DynamicResource CommonFont}"
                   Style="{DynamicResource ListBoxExtendStyleLabel}"
                   VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"
                   ToolTip="{DynamicResource LOCSsvGlobalSearchTooltip}"
                   Visibility="{Binding IsGlobal, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <Image Grid.Column="0" HorizontalAlignment="Center" Height="32" VerticalAlignment="Center" Width="32"
                   Source="{Binding Icon, Converter={StaticResource DefaultIconConverter}}">
                <Image.Style>
                    <Style TargetType="Image">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGlobal}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>

            <controls:TextBlockTrimmed Grid.Column="2"
                                       Style="{DynamicResource ListBoxExtendStyleTextBlock}"
                                       Text="{Binding DisplayName}"
                                       ToolTip="{Binding DisplayName}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Stretch" />

            <Viewbox Grid.Column="4" Width="32" Height="32"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Stretch="Uniform"
                     ToolTip="{Binding SourceName}">
                <Viewbox.Style>
                    <Style TargetType="Viewbox">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGlobal}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Viewbox.Style>
                <Label Content="{Binding SourceIcon}" FontFamily="{DynamicResource CommonFont}"
                       Style="{DynamicResource ListBoxExtendStyleLabel}"
                       FontSize="32" Padding="0" />
            </Viewbox>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
